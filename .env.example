# MuseWave Environment Configuration
# Copy to `.env` and fill with real values.

# Backend
MONGO_URL=mongodb://localhost:27017
DB_NAME=musewave_db
# Optional fallback db used for login lookup compatibility
LEGACY_DB_NAME=musewave_db
PORT=8000
ENV=development
CORS_ORIGINS=*

# AI Suggestions + Lyrics (Required for non-template suggestions)
OPENAI_API_KEY=sk-proj-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Real Music Generation Provider (Optional but recommended)
# Point this to your own music generation service endpoint.
# Expected response should include an audio URL in one of:
# audio_url | url | output_url | result_url | output
# Gemini-compatible providers can also return inline/base64 audio data.
MUSICGEN_API_URL=
MUSICGEN_API_KEY=
# Provider chunking control (Gemini/music models often cap ~30s per generation)
MUSICGEN_MAX_CHUNK_SECONDS=30
MUSICGEN_REQUEST_TIMEOUT_SECONDS=240
# Replicate-hosted music generation (used when MUSICGEN_API_URL is empty)
REPLICATE_MUSIC_MODEL=meta/musicgen:671ac645ce5e552cc63a54a2bbff63fcf798043055d2dac5fc9e36a837eedcfb
REPLICATE_MUSIC_MODEL_VERSION=stereo-large
REPLICATE_MUSIC_OUTPUT_FORMAT=mp3
REPLICATE_MUSIC_NORMALIZATION_STRATEGY=peak
REPLICATE_MUSIC_MAX_DURATION_SECONDS=30

# AI Video Generation (Optional)
REPLICATE_API_TOKEN=
# Keep false when you want real provider generation.
FREE_TIER_MODE=false
STRICT_REAL_MEDIA_OUTPUT=false

# Frontend
REACT_APP_BACKEND_URL=https://muse-wave-backend.vercel.app
REACT_APP_SUGGEST_BACKEND_URL=https://muse-wave-backend.vercel.app
