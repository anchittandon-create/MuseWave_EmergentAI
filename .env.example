# MuseWave Next.js + Firebase + Gemini Environment
# Copy to `.env.local` (for local) or environment settings in deployment.

# ==================== Google Cloud / Firebase ====================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
FIREBASE_PROJECT_ID=your-gcp-project-id
FIREBASE_STORAGE_BUCKET=your-gcp-project-id.appspot.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-gcp-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional alternative to the 3 vars above:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ==================== Gemini Music Generation ====================
# Vertex model for music synthesis (30-second segment generation calls)
GEMINI_MUSIC_MODEL=lyria-002
GEMINI_MUSIC_TIMEOUT_MS=300000

# Gemini model for AI suggest + segment metadata extraction
GEMINI_REASONING_MODEL=gemini-2.5-flash
GEMINI_SUGGEST_MODEL=gemini-2.5-flash
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

# ==================== Optional Video (post-audio) ====================
# Provide your own service endpoint if needed.
VIDEO_GENERATION_ENDPOINT=
VIDEO_GENERATION_API_KEY=
